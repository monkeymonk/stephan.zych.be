---
layout: base.njk
title: Blog — Stéphan Zych
permalink: /blog/
---
{% set allTags = collections.blog | collectTags(['blog']) %}
<sz-portfolio layout="list" filters="{{ allTags | join(',') }}" page-size="10">
  <div class="post-list">
    {% for group in collections.blog | groupByMonth %}
    <details class="post-group" data-month="{{ group.key }}" open>
      <summary class="post-month">{{ group.label }}<span class="post-month__count">{{ group.posts | length }}</span></summary>
      <ul class="post-group__items">
        {% for post in group.posts %}
        <li data-tags="{{ post.data.tags | join(',') }}">
          <a class="post-row" href="{{ post.url }}">
            <span class="post-row__date">
              <time datetime="{{ post.date | htmlDateString }}">{{ post.date | htmlDateString }}</time>
              <span class="post-row__read">{{ post.templateContent | readingTime }} min read</span>
            </span>
            <span class="post-row__main">
              <span class="post-row__title">{{ post.data.title }}</span>
              {% if post.data.series %}<span class="post-row__series">{{ seriesData[post.data.series].name if seriesData[post.data.series] else post.data.series }}{% if post.data.order %} · part {{ post.data.order }}{% endif %}</span>{% endif %}
              <span class="post-row__desc">{{ post.data.description }}</span>
              {% if post.data.tags %}
              <span class="post-row__tags">
                {% for tag in post.data.tags %}{% if tag !== 'blog' %}<span class="post-row__tag">{{ tag }}</span>{% endif %}{% endfor %}
              </span>
              {% endif %}
            </span>
            <span class="post-row__arrow">→</span>
          </a>
        </li>
        {% endfor %}
      </ul>
    </details>
    {% endfor %}
  </div>
</sz-portfolio>
