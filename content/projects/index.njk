---
layout: base.njk
title: Projects — Stéphan Zych
permalink: /projects/
---
{% set allTags = [] %}
{% for project in collections.projects %}
  {% for tag in project.data.tags or [] %}
    {% if tag not in allTags %}
      {% set allTags = (allTags.push(tag), allTags) %}
    {% endif %}
  {% endfor %}
{% endfor %}
<sz-portfolio filters="{{ allTags | join(',') }}" page-size="20">
  {% for project in collections.projects %}
    <a class="project-pane" href="{{ project.url }}" data-tags="{{ project.data.tags | join(',') }}">
      <span class="project-pane__num" aria-hidden="true">{{ loop.index0 }}</span>
      <h3 class="project-pane__title">{{ project.data.title }}</h3>
      <p class="project-pane__desc">{{ project.data.description }}</p>
      {% if project.data.tags %}
      <span class="project-pane__tags">
        {% for tag in project.data.tags %}<span class="project-pane__tag">{{ tag }}</span>{% endfor %}
      </span>
      {% endif %}
    </a>
  {% endfor %}
</sz-portfolio>
