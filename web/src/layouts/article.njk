---
layout: base.njk
---
{% import "share-links.njk" as share %}
<sz-toc></sz-toc>
<article class="sz-article">
  <div class="sz-article__toolbar">
    {% if section %}
    <nav class="sz-article__breadcrumb" aria-label="Breadcrumb">
      <a href="/">~</a>
      <span class="sz-article__crumb-sep">/</span>
      <a href="{{ section.path }}">{{ section.name }}</a>
      <span class="sz-article__crumb-sep">/</span>
      <span class="sz-article__crumb-current">{{ page.fileSlug }}</span>
    </nav>
    {% endif %}
    <sz-view-toggle class="sz-article__view"></sz-view-toggle>
  </div>

  {# Styled chrome — shown only in reading (glow) view #}
  {% if poster %}
  <div class="sz-article__hero">
    <img src="{{ poster }}" alt="{{ title }}" fetchpriority="high" decoding="async"{{ poster | imgDimAttrs | safe }}>
  </div>
  {% endif %}
  <header class="sz-article__header">
    <h1 class="sz-article__title">{{ heading or title }}</h1>
    {% if date or tags or section.name == 'blog' %}
    <div class="sz-article__meta">
      {% if date %}<time datetime="{{ date | htmlDateString }}">{{ date | dateDisplay }}</time>{% endif %}
      {% if section.name == 'blog' %}<span class="sz-article__read">{{ content | readingTime }} min read</span>{% endif %}
      {% if tags %}
      <span class="sz-article__tags">
        {% for tag in tags %}{% if tag !== 'blog' and tag !== 'projects' %}<span class="sz-article__tag">{{ tag }}</span>{% endif %}{% endfor %}
      </span>
      {% endif %}
    </div>
    {% endif %}
    {% if description %}
    <p class="sz-article__description">{{ description }}</p>
    {% endif %}
    {% if section.name == 'projects' and (client or role or timeframe or liveUrl) %}
    <dl class="sz-article__facts">
      {% if client %}<div class="sz-fact"><dt>Client</dt><dd>{{ client }}</dd></div>{% endif %}
      {% if role %}<div class="sz-fact"><dt>Role</dt><dd>{{ role }}</dd></div>{% endif %}
      {% if timeframe %}<div class="sz-fact"><dt>When</dt><dd>{{ timeframe }}</dd></div>{% endif %}
      {% if liveUrl %}<div class="sz-fact"><dt>Live</dt><dd><a href="{{ liveUrl }}" rel="noopener">{{ liveUrl | replace('https://','') | replace('http://','') }}</a></dd></div>{% endif %}
    </dl>
    {% endif %}
  </header>

  {% include "series-nav.njk" %}

  <sz-markdown line-numbers class="sz-article__body">
    {# Markdown header — inside the numbered body, shown in code view #}
    <div class="sz-md-header">
      <div class="md-h1"><span class="md-hash"># </span>{{ heading or title }}</div>
      {% if date or tags or section.name == 'blog' %}
      <div class="md-meta">
        {% if date %}<span class="md-date">{{ date | htmlDateString }}</span>{% endif %}
        {% if section.name == 'blog' %}<span class="md-read">{{ content | readingTime }} min read</span>{% endif %}
        {% if tags %}{% for tag in tags %}{% if tag !== 'blog' and tag !== 'projects' %}<span class="md-tag">#{{ tag }}</span>{% endif %}{% endfor %}{% endif %}
      </div>
      {% endif %}
      {% if description %}<blockquote class="md-desc">{{ description }}</blockquote>{% endif %}
      {% if section.name == 'projects' and (client or role or timeframe or liveUrl) %}<div class="md-facts">{% if client %}<span class="md-fact"><span class="md-fact-key">client:</span> {{ client }}</span>{% endif %}{% if role %}<span class="md-fact"><span class="md-fact-key">role:</span> {{ role }}</span>{% endif %}{% if timeframe %}<span class="md-fact"><span class="md-fact-key">when:</span> {{ timeframe }}</span>{% endif %}{% if liveUrl %}<span class="md-fact"><span class="md-fact-key">live:</span> <a href="{{ liveUrl }}" rel="noopener">{{ liveUrl | replace('https://','') | replace('http://','') }}</a></span>{% endif %}</div>{% endif %}
      {% if poster %}<img class="md-img" src="{{ poster }}" alt="{{ heading or title }}" loading="lazy" decoding="async"{{ poster | imgDimAttrs | safe }}>{% endif %}
    </div>

    {% include "series-source.njk" %}

    {{ content | safe }}

    {% if section.name == 'blog' %}
    {% set shareUrl = (site.url + page.url) | urlencode %}
    {% set shareText = title | urlencode %}
    <div class="sz-md-footer">
      <div class="md-hr">---</div>
      <div class="md-foot">written by <strong>{{ site.author }}</strong> · <a href="/about/">~/about</a></div>
      <div class="md-foot">share: {{ share.shareLinks(shareUrl, shareText) }}</div>
    </div>
    {% endif %}
  </sz-markdown>

  {# Styled footer — shown only in reading (glow) view #}
  {% if section.name == 'blog' %}
  {% set shareUrl = (site.url + page.url) | urlencode %}
  {% set shareText = title | urlencode %}
  <footer class="sz-article__footer">
    <div class="sz-article__author">
      <div class="sz-article__author-name">{{ site.author }}</div>
      <p class="sz-article__author-bio">Lead developer &amp; frontend architect in Brussels. <a href="/about/">More about me →</a></p>
    </div>
    <div class="sz-article__share">
      <span class="sz-article__share-label">Share</span>
      {{ share.shareLinks(shareUrl, shareText, true, "\n      ") }}
    </div>
  </footer>
  {% endif %}

  {# Previous / next within the same section (blog or projects) #}
  {% set sectionItems = collections[section.name] %}
  {% if sectionItems %}
  {% if section.name == 'blog' %}
  {# blog is sorted newest-first, so read it chronologically: prev = older, next = newer #}
  {% set prevItem = sectionItems | getNextCollectionItem %}
  {% set nextItem = sectionItems | getPreviousCollectionItem %}
  {% else %}
  {% set prevItem = sectionItems | getPreviousCollectionItem %}
  {% set nextItem = sectionItems | getNextCollectionItem %}
  {% endif %}
  {% if prevItem or nextItem %}
  <nav class="sz-article__pager" aria-label="{{ section.name }} navigation">
    {% if prevItem %}
    <a class="sz-pager__link sz-pager__link--prev" href="{{ prevItem.url }}" rel="prev">
      <span class="sz-pager__dir">← Prev</span>
      <span class="sz-pager__title">{{ prevItem.data.title }}</span>
    </a>
    {% else %}<span class="sz-pager__spacer"></span>{% endif %}
    {% if nextItem %}
    <a class="sz-pager__link sz-pager__link--next" href="{{ nextItem.url }}" rel="next">
      <span class="sz-pager__dir">Next →</span>
      <span class="sz-pager__title">{{ nextItem.data.title }}</span>
    </a>
    {% else %}<span class="sz-pager__spacer"></span>{% endif %}
  </nav>
  {% endif %}
  {% endif %}
</article>
