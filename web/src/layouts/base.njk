<!DOCTYPE html>
<html lang="en" data-theme="catppuccin-mocha">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  {%- set metaTitle = title | default(site.title) -%}
  {%- set metaDescription = description | default(site.description) -%}
  {%- set metaImage = site.url + (ogImage or poster or '/assets/social-card.jpg') -%}
  {%- set isArticle = section.name == 'blog' and date -%}
  <title>{{ metaTitle }}</title>
  <meta name="description" content="{{ metaDescription }}">
  {% if noindex %}<meta name="robots" content="noindex, nofollow">{% endif %}
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">
  <meta property="og:type" content="{{ 'article' if isArticle else 'website' }}">
  <meta property="og:site_name" content="{{ site.title }}">
  <meta property="og:locale" content="en_US">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:title" content="{{ metaTitle }}">
  <meta property="og:description" content="{{ metaDescription }}">
  <meta property="og:image" content="{{ metaImage }}">
  {%- if isArticle %}
  <meta property="article:published_time" content="{{ date | htmlDateString }}">
  <meta property="article:author" content="{{ site.author }}">
  {%- for tag in tags %}{% if tag !== 'blog' %}
  <meta property="article:tag" content="{{ tag }}">{% endif %}{%- endfor %}
  {%- endif %}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ metaTitle }}">
  <meta name="twitter:description" content="{{ metaDescription }}">
  <meta name="twitter:image" content="{{ metaImage }}">
  {%- if site.socials.twitter and site.socials.twitter != '#' %}
  <meta name="twitter:creator" content="{{ site.socials.twitter }}">
  {%- endif %}
  {%- if isArticle %}
  <script type="application/ld+json">{"@context":"https://schema.org","@type":"BlogPosting","headline":{{ metaTitle | dump | safe }},"description":{{ metaDescription | dump | safe }},"image":{{ metaImage | dump | safe }},"datePublished":{{ (date | htmlDateString) | dump | safe }},"url":{{ (site.url + page.url) | dump | safe }},"mainEntityOfPage":{{ (site.url + page.url) | dump | safe }},"author":{"@type":"Person","name":{{ site.author | dump | safe }},"url":{{ site.url | dump | safe }}}}</script>
  {%- elif page.url == '/' or page.url == '/about/' %}
  <script type="application/ld+json">{"@context":"https://schema.org","@type":"Person","name":{{ site.author | dump | safe }},"url":{{ site.url | dump | safe }},"jobTitle":"Lead Developer & Frontend Architect","worksFor":{"@type":"Organization","name":"STEPHANZYCH","legalName":"STEPHAN ZYCH SRL","url":"https://stephanzych.be","vatID":"BE 0804.229.671"},"sameAs":[{{ site.socials.github | dump | safe }},{{ site.socials.linkedin | dump | safe }}]}</script>
  {%- endif %}
  <meta name="theme-color" content="#1e1e2e">
  <link rel="icon" href="/assets/favicon.svg" type="image/svg+xml">
  <link rel="preload" href="/assets/fonts/JetBrainsMono-Regular.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/assets/fonts/JetBrainsMono-Bold.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="stylesheet" href="/styles/reset.css">
  <link rel="stylesheet" href="/styles/base.css">
  {% if section.name == 'blog' or section.name == 'projects' or page.fileSlug == 'styleguide' %}
  <link rel="stylesheet" href="/styles/prism-catppuccin.css">
  {% endif %}
  {# Only the default theme ships render-blocking; others load on demand (app/index.ts). #}
  <link rel="stylesheet" id="theme-css-catppuccin-mocha" href="/assets/themes/catppuccin-mocha.css">
  <script type="module" src="/assets/components.js"></script>
  {%- if site.analyticsId %}
  {# Self-hosted, cookieless Umami — no cookies/localStorage, so no consent banner. #}
  <script defer src="https://analytics.zych.be/script.js" data-website-id="{{ site.analyticsId }}"></script>
  {%- endif %}
</head>
<body>
  <script type="application/json" id="sz-nav-data">{{ nav | dump | safe }}</script>
  {%- set socialLinks = [] -%}
  {%- if site.socials.github -%}{%- set socialLinks = (socialLinks.push({ id: "github", label: "GitHub", icon: "github", url: site.socials.github }), socialLinks) -%}{%- endif -%}
  {%- if site.socials.linkedin -%}{%- set socialLinks = (socialLinks.push({ id: "linkedin", label: "LinkedIn", icon: "linkedin", url: site.socials.linkedin }), socialLinks) -%}{%- endif -%}
  {%- if site.email -%}{%- set socialLinks = (socialLinks.push({ id: "email", label: "Email", icon: "mail", url: "mailto:" + site.email }), socialLinks) -%}{%- endif -%}
  <a href="#main-content" class="skip-link">Skip to content</a>

  <sz-background>
    <sz-slideshow mode="slideshow" interval="30000"></sz-slideshow>
  </sz-background>
  <sz-start-screen items='{{ startScreen.items | dump }}'></sz-start-screen>
  <sz-effect-matrix aria-hidden="true"></sz-effect-matrix>
  <sz-effect-confetti aria-hidden="true"></sz-effect-confetti>
  <sz-screen-shader aria-hidden="true"></sz-screen-shader>

  <sz-window-manager>
    <sz-window id="terminal" titlebar="integrated" window-title="stephan.zych.be">
      <sz-tmux-bar slot="bar" active-path="{{ page.url }}" nav='{{ nav.tabs | dump }}'></sz-tmux-bar>
      <sz-tmux-panes>
        <sz-neovim slot="pane-0">
          <main id="main-content" tabindex="-1">
            {{ content | safe }}
          </main>
          <sz-palette shortcuts='{{ shortcuts | dump }}'></sz-palette>
          <sz-links></sz-links>
          <sz-statusbar repo-url="{{ site.repoUrl }}" socials='{{ socialLinks | dump }}'></sz-statusbar>
        </sz-neovim>
      </sz-tmux-panes>
    </sz-window>
  </sz-window-manager>

  <sz-notifications></sz-notifications>
  <sz-copyright-footer></sz-copyright-footer>
</body>
</html>
