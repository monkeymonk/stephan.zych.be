# Copy to `.env` and fill in for local builds. `.env` is gitignored.
# In CI, set WAKAPI_API_KEY and WAKAPI_API_URL as GitHub Actions secrets instead
# (Settings → Secrets and variables → Actions). They are only used at build time
# to fetch coding stats; neither is ever shipped to the browser. The server URL
# is private — leave it out of committed files.
WAKAPI_API_KEY=
WAKAPI_API_URL=
