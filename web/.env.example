# Copy to `.env` and fill in for local builds. `.env` is gitignored.
# In CI, set WAKAPI_API_KEY as a GitHub Actions secret instead (Settings →
# Secrets and variables → Actions). The key is only used at build time to
# fetch coding stats; it is never shipped to the browser.
WAKAPI_API_KEY=
WAKAPI_API_URL=https://wakapi.zych.link
