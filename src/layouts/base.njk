<!DOCTYPE html>
<html lang="en" data-theme="catppuccin-mocha">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title | default("Stephan Zych") }}</title>
  <meta name="description" content="{{ description | default('Software developer portfolio') }}">
  <meta property="og:title" content="{{ title | default('Stephan Zych') }}">
  <meta property="og:description" content="{{ description | default('Software developer portfolio') }}">
  {% if ogImage %}<meta property="og:image" content="{{ ogImage }}">{% endif %}
  <link rel="stylesheet" href="/styles/reset.css">
  <link rel="stylesheet" href="/styles/base.css">
  <link rel="stylesheet" href="/assets/themes/catppuccin-mocha.css">
  <script type="module" src="/assets/components.js"></script>
</head>
<body>
  <script type="application/json" id="sz-nav-data">{{ nav | dump | safe }}</script>
  <script type="application/json" id="sz-commands-data">{{ commands | dump | safe }}</script>
  <a href="#main-content" class="sr-only" style="position:absolute;left:-9999px;top:auto;width:1px;height:1px;overflow:hidden">Skip to content</a>
  <sz-background>
    <sz-screen-shader>
      <sz-terminal window-mode="{{ windowMode | default('windowed') }}">
        <sz-tmux-bar slot="bar" active-path="{{ page.url }}"></sz-tmux-bar>
        <div slot="content" id="main-content">
          {{ content | safe }}
        </div>
        <sz-statusbar slot="statusbar" route="{{ page.url }}"></sz-statusbar>
        <sz-command slot="command"></sz-command>
      </sz-terminal>
    </sz-screen-shader>
  </sz-background>
</body>
</html>
