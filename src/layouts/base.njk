<!DOCTYPE html>
<html lang="en" data-theme="catppuccin-mocha">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title | default("Stephan Zych") }}</title>
  <meta name="description" content="{{ description | default('Software developer portfolio') }}">
  <meta property="og:title" content="{{ title | default('Stephan Zych') }}">
  <meta property="og:description" content="{{ description | default('Software developer portfolio') }}">
  {% if ogImage %}<meta property="og:image" content="{{ ogImage }}">{% endif %}
  <link rel="stylesheet" href="/styles/reset.css">
  <link rel="stylesheet" href="/styles/base.css">
  <link rel="stylesheet" href="/styles/prism-catppuccin.css">
  <link rel="stylesheet" href="/assets/themes/catppuccin-mocha.css">
  <link rel="stylesheet" href="/assets/themes/gruvbox-dark.css">
  <link rel="stylesheet" href="/assets/themes/tokyonight.css">
  <script type="module" src="/assets/components.js"></script>
</head>
<body>
  <script type="application/json" id="sz-nav-data">{{ nav | dump | safe }}</script>
  <script id="sz-site-data" type="application/json">{{ site | dump | safe }}</script>
  <script type="application/json" id="sz-start-screen-data">{{ startScreen | dump | safe }}</script>
  <a href="#main-content" class="sr-only" style="position:absolute;left:-9999px;top:auto;width:1px;height:1px;overflow:hidden">Skip to content</a>

  <sz-background>
    <sz-slideshow mode="slideshow" interval="30000"></sz-slideshow>
  </sz-background>
  <sz-start-screen></sz-start-screen>
  <sz-effect-matrix></sz-effect-matrix>
  <sz-effect-confetti></sz-effect-confetti>
  <sz-screen-shader></sz-screen-shader>

  <sz-window-manager>
    <sz-window id="terminal" titlebar="integrated" title="stephan.zych.be" {% if page.url == "/" %}start-hidden{% endif %}>
      <sz-tmux-bar slot="bar" active-path="{{ page.url }}"></sz-tmux-bar>
      <sz-tmux-panes>
        <sz-neovim slot="pane-0">
          <div id="main-content">
            {{ content | safe }}
          </div>
          <sz-palette></sz-palette>
          <sz-statusbar></sz-statusbar>
        </sz-neovim>
      </sz-tmux-panes>
    </sz-window>
  </sz-window-manager>

  <sz-notifications></sz-notifications>
</body>
</html>
