<!DOCTYPE html>
<html lang="en" data-theme="catppuccin-mocha">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title | default("Stephan Zych") }}</title>
  <meta name="description" content="{{ description | default('Software developer portfolio') }}">
  {% if noindex %}<meta name="robots" content="noindex, nofollow">{% endif %}
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:title" content="{{ title | default('Stephan Zych') }}">
  <meta property="og:description" content="{{ description | default('Software developer portfolio') }}">
  <meta property="og:image" content="{{ site.url }}{{ ogImage | default('/assets/wallpapers/landscape-1.webp') }}">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="theme-color" content="#1e1e2e">
  <link rel="icon" href="/assets/favicon.svg" type="image/svg+xml">
  <link rel="stylesheet" href="/styles/reset.css">
  <link rel="stylesheet" href="/styles/base.css">
  <link rel="stylesheet" href="/styles/prism-catppuccin.css">
  <link rel="stylesheet" href="/assets/themes/catppuccin-mocha.css">
  <link rel="stylesheet" href="/assets/themes/gruvbox-dark.css">
  <link rel="stylesheet" href="/assets/themes/tokyonight.css">
  <script type="module" src="/assets/components.js"></script>
</head>
<body>
  <script type="application/json" id="sz-nav-data">{{ nav | dump | safe }}</script>
  {%- set socialLinks = [] -%}
  {%- if site.socials.github -%}{%- set socialLinks = (socialLinks.push({ id: "github", label: "GitHub", icon: "github", url: site.socials.github }), socialLinks) -%}{%- endif -%}
  {%- if site.socials.linkedin -%}{%- set socialLinks = (socialLinks.push({ id: "linkedin", label: "LinkedIn", icon: "linkedin", url: site.socials.linkedin }), socialLinks) -%}{%- endif -%}
  {%- if site.email -%}{%- set socialLinks = (socialLinks.push({ id: "email", label: "Email", icon: "mail", url: "mailto:" + site.email }), socialLinks) -%}{%- endif -%}
  <a href="#main-content" class="sr-only" style="position:absolute;left:-9999px;top:auto;width:1px;height:1px;overflow:hidden">Skip to content</a>

  <sz-background>
    <sz-slideshow mode="slideshow" interval="30000"></sz-slideshow>
  </sz-background>
  <sz-start-screen items='{{ startScreen.items | dump }}'></sz-start-screen>
  <sz-effect-matrix></sz-effect-matrix>
  <sz-effect-confetti></sz-effect-confetti>
  <sz-screen-shader></sz-screen-shader>

  <sz-window-manager>
    <sz-window id="terminal" titlebar="integrated" title="stephan.zych.be">
      <sz-tmux-bar slot="bar" active-path="{{ page.url }}" nav='{{ nav.tabs | dump }}'></sz-tmux-bar>
      <sz-tmux-panes>
        <sz-neovim slot="pane-0">
          <div id="main-content">
            {{ content | safe }}
          </div>
          <sz-palette shortcuts='{{ shortcuts | dump }}'></sz-palette>
          <sz-statusbar repo-url="{{ site.repoUrl }}" socials='{{ socialLinks | dump }}'></sz-statusbar>
        </sz-neovim>
      </sz-tmux-panes>
    </sz-window>
  </sz-window-manager>

  <sz-notifications></sz-notifications>
</body>
</html>
