---
layout: base.njk
title: Blog — Stephan Zych
permalink: /blog/
---
<sz-markdown>
  <h1>Blog</h1>
  {% for post in collections.blog %}
    <article>
      <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
      <p>{{ post.data.description }}</p>
      <time>{{ post.date | dateDisplay }}</time>
    </article>
  {% endfor %}
</sz-markdown>
