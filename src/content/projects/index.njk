---
layout: base.njk
title: Projects — Stéphan Zych
permalink: /projects/
---
{% set allTags = [] %}
{% for project in collections.projects %}
  {% for tag in project.data.tags or [] %}
    {% if tag not in allTags %}
      {% set allTags = (allTags.push(tag), allTags) %}
    {% endif %}
  {% endfor %}
{% endfor %}
<sz-portfolio filters="{{ allTags | join(',') }}">
  {% for project in collections.projects %}
    <a class="project-card" href="{{ project.url }}" data-tags="{{ project.data.tags | join(',') }}">
      <div class="project-card__bar">
        <span class="project-card__dots"><i></i><i></i><i></i></span>
        <span class="project-card__path">~/projects/{{ project.fileSlug }}</span>
      </div>
      <div class="project-card__body">
        <h3 class="project-card__title">{{ project.data.title }}</h3>
        <p class="project-card__desc">{{ project.data.description }}</p>
        {% if project.data.tags %}
        <div class="project-card__tags">
          {% for tag in project.data.tags %}<span class="project-card__tag">{{ tag }}</span>{% endfor %}
        </div>
        {% endif %}
      </div>
      <div class="project-card__cta">open <span class="project-card__arrow">→</span></div>
    </a>
  {% endfor %}
</sz-portfolio>
