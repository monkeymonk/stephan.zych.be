---
layout: base.njk
title: Projects — Stéphan Zych
permalink: /projects/
---
{% set allTags = [] %}
{% for project in collections.projects %}
  {% for tag in project.data.tags or [] %}
    {% if tag not in allTags %}
      {% set allTags = (allTags.push(tag), allTags) %}
    {% endif %}
  {% endfor %}
{% endfor %}
<sz-portfolio filters="{{ allTags | join(',') }}" page-size="8">
  {% for project in collections.projects %}
    <a class="project-row" href="{{ project.url }}" data-tags="{{ project.data.tags | join(',') }}">
      <span class="project-row__num">{{ loop.index0 }}</span>
      <span class="project-row__main">
        <span class="project-row__title">{{ project.data.title }}</span>
        <span class="project-row__desc">{{ project.data.description }}</span>
      </span>
      {% if project.data.tags %}
      <span class="project-row__tags">
        {% for tag in project.data.tags %}<span class="project-row__tag">{{ tag }}</span>{% endfor %}
      </span>
      {% endif %}
    </a>
  {% endfor %}
</sz-portfolio>
